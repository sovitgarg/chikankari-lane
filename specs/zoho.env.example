# Chikankari Lane — Zoho Books API credentials (TEMPLATE)
# Copy this file to config/zoho.env and fill in (config/ is gitignored).
#   cp specs/zoho.env.example config/zoho.env
#
# Setup walkthrough: specs/02-zoho-books-api-setup.md
#
# How to get these values (5-min one-time setup):
#   1. Go to https://api-console.zoho.in (use .in for India data center)
#   2. Create a "Self Client" application
#   3. Generate a self-client grant token with scope:
#        ZohoBooks.fullaccess.all
#      Set duration to 10 minutes (you'll exchange it for a refresh token immediately)
#   4. Run: python3 scripts/zoho_get_refresh_token.py
#      This exchanges the grant token for a long-lived refresh token (saved here automatically)
#   5. Find your Organization ID in Zoho Books -> Settings -> Organization Profile

# Data center (use 'in' for India, 'com' for US, 'eu' for Europe, etc.)
ZOHO_REGION=in

# OAuth credentials from api-console.zoho.in -> Self Client
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Long-lived refresh token (generated by zoho_get_refresh_token.py)
ZOHO_REFRESH_TOKEN=

# Zoho Books organization ID (Settings -> Organization Profile)
ZOHO_ORG_ID=

# Org name for safety check (script aborts if org name doesn't match)
ZOHO_ORG_NAME=Chikankari Lane
